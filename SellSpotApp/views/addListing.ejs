<%- include('partials/head', { pageTitle: 'Add Listing' }) %>
<body>
  <%- include('partials/navbar', { activePage: 'listings' }) %>

  <main class="site-main">
    <div class="container app-container">
      <div class="row justify-content-center">
        <div class="col-lg-9 col-xl-8">
          <div class="page-heading">
            <p class="text-uppercase small fw-bold mb-2">Sell an item</p>
            <h1>Add a new listing</h1>
            <p>Give buyers the details they need to find and collect your item confidently.</p>
          </div>

          <%- include('partials/flash') %>

          <section class="card" aria-label="Add listing form">
            <div class="card-body">
              <form action="/addListing" method="POST" enctype="multipart/form-data">
                <div class="mb-3">
                  <label for="title" class="form-label">Item title</label>
                  <input type="text" class="form-control" id="title" name="title" maxlength="100" placeholder="Example: Wooden study table" required>
                </div>

                <div class="mb-3">
                  <label for="description" class="form-label">Description <span class="text-muted fw-normal">(optional)</span></label>
                  <textarea class="form-control" id="description" name="description" rows="5" placeholder="Share the item’s condition, size, or anything a buyer should know."></textarea>
                </div>

                <div class="row g-3">
                  <div class="col-md-6">
                    <label for="price" class="form-label">Price</label>
                    <div class="input-group">
                      <span class="input-group-text" aria-hidden="true">$</span>
                      <input type="number" class="form-control" id="price" name="price" min="0" step="0.01" placeholder="0.00" required>
                    </div>
                  </div>

                  <div class="col-md-6">
                    <label for="category" class="form-label">Category</label>
                    <select class="form-select" id="category" name="category" required>
                      <option value="">Select a category</option>
                      <option value="Electronics">Electronics</option>
                      <option value="Fashion">Fashion</option>
                      <option value="Home">Home</option>
                      <option value="Books">Books</option>
                      <option value="Sports">Sports</option>
                      <option value="Others">Others</option>
                    </select>
                  </div>

                  <div class="col-md-6">
                    <label for="condition" class="form-label">Condition</label>
                    <select class="form-select" id="condition" name="condition" required>
                      <option value="">Select condition</option>
                      <option value="new">New</option>
                      <option value="like_new">Like New</option>
                      <option value="good">Good</option>
                      <option value="fair">Fair</option>
                      <option value="worn">Worn</option>
                    </select>
                  </div>

                  <div class="col-md-6">
                    <label for="location" class="form-label">Meet-up location</label>
                    <input type="text" class="form-control" id="location" name="location" maxlength="255" placeholder="Example: Tampines MRT Station" required>
                  </div>
                </div>

                <div class="mt-3 mb-4">
                  <label for="image" class="form-label">Item image <span class="text-muted fw-normal">(optional)</span></label>
                  <input type="file" class="form-control" id="image" name="image" accept="image/*">
                  <div class="form-text">Use a clear image so buyers can recognise the item easily.</div>
                </div>

                <div class="d-flex flex-column flex-sm-row gap-2 justify-content-end">
                  <a href="/" class="btn btn-secondary">Cancel</a>
                  <button type="submit" class="btn btn-primary">Publish listing</button>
                </div>
              </form>
            </div>
          </section>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
