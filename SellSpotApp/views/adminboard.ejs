<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Admin Board - SellSpot</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    ></script>

    <link rel="stylesheet" href="/style.css">
</head>

<body>

<nav class="navbar navbar-expand-lg bg-dark navbar-dark">
    <div class="container">

        <a class="navbar-brand" href="/">
            <h3 class="mb-0">SellSpot</h3>
        </a>

        <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#adminNavbar"
            aria-controls="adminNavbar"
            aria-expanded="false"
            aria-label="Toggle navigation"
        >
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="adminNavbar">

            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/">Marketplace</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/myListings">
                        Manage Listings
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link active" href="/adminboard">
                        Admin Board
                    </a>
                </li>
            </ul>

            <ul class="navbar-nav align-items-lg-center">
                <% if (currentUser) { %>
                    <li class="nav-item">
                        <span class="nav-link text-white">
                            <%= currentUser.name %>
                            <span class="badge bg-danger ms-1">Admin</span>
                        </span>
                    </li>

                    <li class="nav-item">
                        <a class="btn btn-outline-light" href="/logout">
                            Logout
                        </a>
                    </li>
                <% } %>
            </ul>

        </div>
    </div>
</nav>

<main class="container mt-5 mb-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h1>Admin Board</h1>

            <p class="text-muted mb-0">
                Search users, filter accounts by role and manage account permissions.
            </p>
        </div>

        <div class="mt-3 mt-md-0">
            <a href="/" class="btn btn-outline-secondary">
                Back to Marketplace
            </a>
        </div>
    </div>


<!-- Eant: filter users by role -->
<div class="card shadow-sm mt-4">
    <div class="card-body">

        <form action="/adminboard" method="GET">

            <div class="row g-3">

                <div class="col-md-8">
                    <label for="role" class="form-label">
                        Filter users by role
                    </label>

                    <select
                        class="form-select"
                        id="role"
                        name="role"
                    >
                        <option
                            value=""
                            <%= role === '' ? 'selected' : '' %>
                        >
                            All Roles
                        </option>

                        <option
                            value="user"
                            <%= role === 'user' ? 'selected' : '' %>
                        >
                            Regular Users
                        </option>

                        <option
                            value="admin"
                            <%= role === 'admin' ? 'selected' : '' %>
                        >
                            Administrators
                        </option>
                    </select>
                </div>

                <div class="col-md-2 d-grid align-items-end">
                    <button type="submit" class="btn btn-primary">
                        Apply Filter
                    </button>
                </div>

                <div class="col-md-2 d-grid align-items-end">
                    <a href="/adminboard" class="btn btn-outline-secondary">
                        Clear
                    </a>
                </div>

            </div>
<div class="mt-3">
  <a href="/" class="btn btn-outline-secondary">
    Clear Search and Filters
  </a>
</div>
        </form>

    </div>
</div>


<!-- Eant: display filtered users -->
<div class="card shadow-sm mt-4">

    <div class="card-header bg-dark text-white">
        <h2 class="h5 mb-0">User Accounts</h2>
    </div>

    <div class="card-body">

        <p>
            <strong>Users found:</strong>
            <%= users.length %>
        </p>

        <% if (users.length > 0) { %>

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead>
                        <tr>
                            <th>User ID</th>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Rating</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% users.forEach((user) => { %>

                            <tr>
                                <td><%= user.user_id %></td>
                                <td><%= user.full_name %></td>
                                <td><%= user.email %></td>
                                <td><%= user.role %></td>
                                <td><%= user.rating %></td>
                            </tr>

                        <% }) %>

                    </tbody>

                </table>

            </div>

        <% } else { %>

            <div class="alert alert-secondary mb-0">
                No users found for the selected role.
            </div>

        <% } %>

    </div>

</div>

</main>

</body>
</html>