<%- include('partials/head', { pageTitle: 'Admin Board' }) %>
<body>
  <%- include('partials/navbar', { activePage: 'admin' }) %>

  <main class="site-main">
    <div class="container app-container">
      <div class="page-heading">
        <p class="text-uppercase small fw-bold mb-2">Admin tools</p>
        <h1>Admin board</h1>
        <p>Review user accounts, adjust roles, and manage account access.</p>
      </div>

      <%- include('partials/flash') %>

      <section class="surface-card filter-panel mb-4" aria-label="Filter user accounts">
        <form action="/adminboard" method="GET">
          <div class="row g-3 align-items-end">
            <div class="col-md-8">
              <label for="role" class="form-label">Filter users by role</label>
              <select class="form-select" id="role" name="role">
                <option value="" <%= role === '' ? 'selected' : '' %>>All roles</option>
                <option value="user" <%= role === 'user' ? 'selected' : '' %>>Regular users</option>
                <option value="admin" <%= role === 'admin' ? 'selected' : '' %>>Administrators</option>
              </select>
            </div>
            <div class="col-md-2 d-grid"><button type="submit" class="btn btn-primary">Apply filter</button></div>
            <div class="col-md-2 d-grid"><a href="/adminboard" class="btn btn-secondary">Clear</a></div>
          </div>
        </form>
      </section>

      <section aria-labelledby="accounts-title">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
          <h2 id="accounts-title" class="h4 mb-0">User accounts</h2>
          <span class="text-muted"><strong><%= users.length %></strong> account<%= users.length === 1 ? '' : 's' %> found</span>
        </div>

        <% if (users.length > 0) { %>
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead class="table-dark">
                <tr>
                  <th scope="col">User</th>
                  <th scope="col">Email</th>
                  <th scope="col">Role</th>
                  <th scope="col">Rating</th>
                  <th scope="col">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach((user) => { %>
                  <tr>
                    <td>
                      <div class="fw-bold"><%= user.full_name %></div>
                      <div class="small text-muted">ID: <%= user.user_id %></div>
                    </td>
                    <td><%= user.email %></td>
                    <td><span class="role-badge"><%= user.role %></span></td>
                    <td><%= user.rating %>/5</td>
                    <td>
                      <% if (user.user_id !== currentUser.id) { %>
                        <div class="d-flex flex-column flex-xl-row gap-2">
                          <form action="/adminboard/update-role/<%= user.user_id %>" method="POST" class="d-flex gap-1">
                            <label class="visually-hidden" for="role-<%= user.user_id %>">Role for <%= user.full_name %></label>
                            <select class="form-select form-select-sm" id="role-<%= user.user_id %>" name="role">
                              <option value="user" <%= user.role === 'user' ? 'selected' : '' %>>User</option>
                              <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>Admin</option>
                            </select>
                            <button type="submit" class="btn btn-sm btn-primary">Save</button>
                          </form>
                          <form action="/adminboard/delete-user/<%= user.user_id %>" method="POST" onsubmit="return confirm('Delete this user account?')">
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                          </form>
                        </div>
                      <% } else { %>
                        <span class="text-muted">Current account</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="empty-state">
            <div class="empty-state-icon" aria-hidden="true">⌕</div>
            <h2 class="h5">No user accounts found</h2>
            <p class="mb-0">Try changing or clearing the role filter.</p>
          </div>
        <% } %>
      </section>
    </div>
  </main>

  <%- include('partials/footer') %>
