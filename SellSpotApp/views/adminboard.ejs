<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>User Management - SellSpot</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
    </script>

    <link rel="stylesheet" href="/style.css">
</head>

<body>

<nav class="navbar navbar-expand-lg bg-dark navbar-dark">
    <div class="container">
        <a class="navbar-brand" href="/">SellSpot</a>

        <div class="d-flex gap-2">
            <a href="/" class="btn btn-outline-light">Home</a>
            <a href="/logout" class="btn btn-danger">Log Out</a>
        </div>
    </div>
</nav>

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>User Management</h1>
            <p class="text-muted mb-0">
                Search users, filter by role and manage account permissions.
            </p>
        </div>
    </div>

    <% if (success && success.length > 0) { %>
        <div class="alert alert-success">
            <%= success[0] %>
        </div>
    <% } %>

    <% if (error && error.length > 0) { %>
        <div class="alert alert-danger">
            <%= error[0] %>
        </div>
    <% } %>

    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <form method="GET" action="/admin/users">
                <div class="row g-3">

                    <div class="col-md-7">
                        <label for="search" class="form-label">
                            Search
                        </label>

                        <input
                            type="text"
                            class="form-control"
                            id="search"
                            name="search"
                            placeholder="Search by full name or email"
                            value="<%= search %>"
                        >
                    </div>

                    <div class="col-md-3">
                        <label for="role" class="form-label">
                            Filter by role
                        </label>

                        <select
                            class="form-select"
                            id="role"
                            name="role"
                        >
                            <option value=""
                                <%= selectedRole === '' ? 'selected' : '' %>>
                                All roles
                            </option>

                            <option value="admin"
                                <%= selectedRole === 'admin' ? 'selected' : '' %>>
                                Admin
                            </option>

                            <option value="user"
                                <%= selectedRole === 'user' ? 'selected' : '' %>>
                                User
                            </option>
                        </select>
                    </div>

                    <div class="col-md-2 d-flex align-items-end">
                        <button
                            type="submit"
                            class="btn btn-primary w-100"
                        >
                            Search
                        </button>
                    </div>

                </div>
            </form>

            <div class="mt-3">
                <a href="/admin/users" class="btn btn-outline-secondary">
                    Clear Search
                </a>
            </div>

        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">
            <strong><%= users.length %> user(s) found</strong>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">

                <thead class="table-dark">
                    <tr>
                        <th>User ID</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Rating</th>
                        <th>Current Role</th>
                        <th>Change Role</th>
                    </tr>
                </thead>

                <tbody>

                    <% if (users.length === 0) { %>
                        <tr>
                            <td colspan="6" class="text-center py-4">
                                No users found.
                            </td>
                        </tr>
                    <% } %>

                    <% users.forEach(user => { %>
                        <tr>
                            <td><%= user.user_id %></td>

                            <td><%= user.full_name %></td>

                            <td><%= user.email %></td>

                            <td><%= user.rating %></td>

                            <td>
                                <% if (user.role === 'admin') { %>
                                    <span class="badge bg-danger">
                                        Admin
                                    </span>
                                <% } else { %>
                                    <span class="badge bg-primary">
                                        User
                                    </span>
                                <% } %>
                            </td>

                            <td>
                                <form
                                    action="/admin/users/<%= user.user_id %>/role"
                                    method="POST"
                                    class="d-flex gap-2"
                                >
                                    <select
                                        name="role"
                                        class="form-select form-select-sm"
                                    >
                                        <option
                                            value="user"
                                            <%= user.role === 'user' ? 'selected' : '' %>
                                        >
                                            User
                                        </option>

                                        <option
                                            value="admin"
                                            <%= user.role === 'admin' ? 'selected' : '' %>
                                        >
                                            Admin
                                        </option>
                                    </select>

                                    <button
                                        type="submit"
                                        class="btn btn-sm btn-success"
                                    >
                                        Update
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>

                </tbody>
            </table>
        </div>
    </div>

</div>

</body>
</html>