<%- include('partials/head', { pageTitle: 'Edit Listing' }) %>
<body>
  <%- include('partials/navbar', { activePage: 'listings' }) %>

  <main class="site-main">
    <div class="container app-container">
      <div class="row justify-content-center">
        <div class="col-lg-9 col-xl-8">
          <div class="page-heading">
            <p class="text-uppercase small fw-bold mb-2">Your listing</p>
            <h1>Edit listing</h1>
            <p>Update the details buyers see. Leave the image empty to keep the current one.</p>
          </div>

          <section class="card" aria-label="Edit listing form">
            <div class="card-body">
              <form action="/editListing/<%= listing.item_id %>" method="POST" enctype="multipart/form-data">
                <div class="mb-3">
                  <label for="title" class="form-label">Item title</label>
                  <input type="text" class="form-control" id="title" name="title" value="<%= listing.item_name %>" maxlength="100" required>
                </div>

                <div class="mb-3">
                  <label for="description" class="form-label">Description</label>
                  <textarea class="form-control" id="description" name="description" rows="5" required><%= listing.description || '' %></textarea>
                </div>

                <div class="row g-3">
                  <div class="col-md-6">
                    <label for="price" class="form-label">Price</label>
                    <div class="input-group">
                      <span class="input-group-text" aria-hidden="true">$</span>
                      <input type="number" class="form-control" id="price" name="price" value="<%= listing.price %>" min="0" step="0.01" required>
                    </div>
                  </div>

                  <div class="col-md-6">
                    <label for="category" class="form-label">Category</label>
                    <select class="form-select" id="category" name="category" required>
                      <option value="Electronics" <%= listing.category_id === 'Electronics' ? 'selected' : '' %>>Electronics</option>
                      <option value="Fashion" <%= listing.category_id === 'Fashion' ? 'selected' : '' %>>Fashion</option>
                      <option value="Home" <%= listing.category_id === 'Home' ? 'selected' : '' %>>Home</option>
                      <option value="Books" <%= listing.category_id === 'Books' ? 'selected' : '' %>>Books</option>
                      <option value="Sports" <%= listing.category_id === 'Sports' ? 'selected' : '' %>>Sports</option>
                      <option value="Others" <%= listing.category_id === 'Others' ? 'selected' : '' %>>Others</option>
                    </select>
                  </div>

                  <div class="col-md-6">
                    <label for="condition" class="form-label">Condition</label>
                    <select class="form-select" id="condition" name="condition" required>
                      <option value="new" <%= listing.condition_status === 'new' ? 'selected' : '' %>>New</option>
                      <option value="like_new" <%= listing.condition_status === 'like_new' ? 'selected' : '' %>>Like New</option>
                      <option value="good" <%= listing.condition_status === 'good' ? 'selected' : '' %>>Good</option>
                      <option value="fair" <%= listing.condition_status === 'fair' ? 'selected' : '' %>>Fair</option>
                      <option value="worn" <%= listing.condition_status === 'worn' ? 'selected' : '' %>>Worn</option>
                    </select>
                  </div>

                  <div class="col-md-6">
                    <label for="location" class="form-label">Meet-up location</label>
                    <input type="text" class="form-control" id="location" name="location" value="<%= listing.location || '' %>" required>
                  </div>
                </div>

                <div class="mt-3 mb-4">
                  <label for="image" class="form-label">Replace image <span class="text-muted fw-normal">(optional)</span></label>
                  <input type="file" class="form-control" id="image" name="image" accept="image/*">
                </div>

                <div class="d-flex flex-column flex-sm-row gap-2 justify-content-end">
                  <a href="/listing/<%= listing.item_id %>" class="btn btn-secondary">Cancel</a>
                  <button type="submit" class="btn btn-primary">Save changes</button>
                </div>
              </form>
            </div>
          </section>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
