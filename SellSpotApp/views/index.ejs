<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <title>SellSpot</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <link rel="stylesheet" href="/style.css">
</head>

<body>

  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">

    <div class="container">

      <a class="navbar-brand" href="/">
        <h3>SellSpot</h3>
      </a>

      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#mainNavbar"
      >
        <span class="navbar-toggler-icon"></span>
      </button>

      <div
        class="collapse navbar-collapse"
        id="mainNavbar"
      >

        <ul class="navbar-nav me-auto">

          <% if (currentUser) { %>

            <li class="nav-item">
              <a
                class="nav-link"
                href="/addListing"
              >
                Add Listing
              </a>
            </li>

            <li class="nav-item">
              <a
                class="nav-link"
                href="/myListings"
              >
                <%= currentUser.role === 'admin'
                  ? 'Manage Listings'
                  : 'My Listings'
                %>
              </a>
            </li>

            <% if (currentUser.role === 'admin') { %>

              <li class="nav-item">
                <a
                  class="nav-link"
                  href="/adminboard"
                >
                  Admin Board
                </a>
              </li>

            <% } %>

          <% } %>

        </ul>

        <ul class="navbar-nav">

                <% if (currentUser) { %>
                    <li class="nav-item">
                        <span class="nav-link text-white">
                            <%= currentUser.name %>
                            <span class="badge bg-danger ms-1">Admin</span>
                        </span>
                    </li>

            <li class="nav-item">
              <a
                class="btn btn-outline-light"
                href="/logout"
              >
                Logout
              </a>
            </li>

          <% } else { %>

            <li class="nav-item">
              <a
                class="btn btn-outline-light"
                href="/register"
              >
                Register
              </a>
            </li>

            <li class="nav-item">
              <a
                class="btn btn-outline-light"
                href="/login"
              >
                Login
              </a>
            </li>

          <% } %>

        </ul>

      </div>

    </div>

  </nav>

  <div class="container">

    <div
      id="myCarousel"
      class="carousel slide"
      data-bs-ride="carousel"
      data-bs-interval="5000"
    >

      <div class="carousel-indicators">

        <button
          type="button"
          data-bs-target="#myCarousel"
          data-bs-slide-to="0"
          class="active"
          aria-current="true"
          aria-label="Slide 1"
        ></button>

        <button
          type="button"
          data-bs-target="#myCarousel"
          data-bs-slide-to="1"
          aria-label="Slide 2"
        ></button>

      </div>

      <div class="carousel-inner">

        <div class="carousel-item active">

          <div class="alert-slide alert-orange">

            <% if (currentUser) { %>

              <h2>
                Welcome to SellSpot,
                <%= currentUser.name %>
              </h2>

            <% } else { %>

              <h2>Welcome to SellSpot</h2>

            <% } %>

            <p>
              Find affordable items or create a listing
              for something you no longer need.
            </p>

          </div>

        </div>

        <div class="carousel-item">

          <div class="alert-slide alert-red">

            <h2>Beware of Scams</h2>

            <p>
              SellSpot Employees will never ask for payment.
            </p>

          </div>

        </div>

      </div>

    </div>

  </div>

  <div class="container mt-4">

    <% if (success.length > 0) { %>

      <div class="alert alert-success">
        <%= success[0] %>
      </div>

    <% } %>

    <% if (error.length > 0) { %>

      <div class="alert alert-danger">
        <%= error[0] %>
      </div>

    <% } %>

    <div class="p-4 mb-4 bg-primary text-white rounded">

      <h1>
        Buy and sell second-hand items
      </h1>

      <p class="mb-0">
        Find affordable items or create a listing
        for something you no longer need.
      </p>

    </div>

<!-- Eant: search, filtering and sorting controls -->
<form action="/" method="GET" class="card card-body mb-4">

  <div class="row g-3">

    <div class="col-md-4">
      <label for="search" class="form-label">
        Search item
      </label>

      <input
        type="text"
        class="form-control"
        id="search"
        name="search"
        value="<%= search %>"
        placeholder="Search item name or description"
      >
    </div>

    <div class="col-md-2">
      <label for="category" class="form-label">
        Category
      </label>

      <select
        class="form-select"
        id="category"
        name="category"
      >
        <option value="">All categories</option>

        <option
          value="1"
          <%= String(category) === '1' ? 'selected' : '' %>
        >
          Electronics
        </option>

        <option
          value="2"
          <%= String(category) === '2' ? 'selected' : '' %>
        >
          Fashion
        </option>

        <option
          value="3"
          <%= String(category) === '3' ? 'selected' : '' %>
        >
          Home
        </option>

        <option
          value="4"
          <%= String(category) === '4' ? 'selected' : '' %>
        >
          Books
        </option>

        <option
          value="5"
          <%= String(category) === '5' ? 'selected' : '' %>
        >
          Others
        </option>
      </select>
    </div>

    <div class="col-md-2">
      <label for="condition" class="form-label">
        Condition
      </label>

      <select
        class="form-select"
        id="condition"
        name="condition"
      >
        <option value="">All conditions</option>

        <option
          value="new"
          <%= condition === 'new' ? 'selected' : '' %>
        >
          New
        </option>

        <option
          value="like_new"
          <%= condition === 'like_new' ? 'selected' : '' %>
        >
          Like New
        </option>

        <option
          value="good"
          <%= condition === 'good' ? 'selected' : '' %>
        >
          Good
        </option>

        <option
          value="fair"
          <%= condition === 'fair' ? 'selected' : '' %>
        >
          Fair
        </option>

        <option
          value="worn"
          <%= condition === 'worn' ? 'selected' : '' %>
        >
          Worn
        </option>
      </select>
    </div>

    <div class="col-md-2">
      <label for="sort" class="form-label">
        Sort by
      </label>

      <select
        class="form-select"
        id="sort"
        name="sort"
      >
        <option
          value="newest"
          <%= sort === 'newest' ? 'selected' : '' %>
        >
          Newest
        </option>

        <option
          value="oldest"
          <%= sort === 'oldest' ? 'selected' : '' %>
        >
          Oldest
        </option>

        <option
          value="priceLow"
          <%= sort === 'priceLow' ? 'selected' : '' %>
        >
          Price: Low to High
        </option>

        <option
          value="priceHigh"
          <%= sort === 'priceHigh' ? 'selected' : '' %>
        >
          Price: High to Low
        </option>

        <option
          value="nameAZ"
          <%= sort === 'nameAZ' ? 'selected' : '' %>
        >
          Name: A–Z
        </option>
      </select>
    </div>

    <div class="col-md-2 d-grid align-items-end">
      <button type="submit" class="btn btn-dark">
        Apply
      </button>
    </div>

  </div>

  <div class="mt-3">
    <a href="/" class="btn btn-outline-secondary">
      Clear Search and Filters
    </a>
  </div>

</form>

    <div class="d-flex justify-content-between align-items-center mb-3">

      <h2>Marketplace Listings</h2>

      <% if (currentUser) { %>

        <a
          href="/addListing"
          class="btn btn-success"
        >
          Add New Listing
        </a>

      <% } %>

    </div>

    <% if (listings.length > 0) { %>

      <div class="row g-4">

        <% for (let i = 0; i < listings.length; i++) { %>

          <div class="col-md-6 col-lg-4">

            <div class="card h-100 shadow-sm">

              <% if (listings[i].hasDatabaseImage) { %>

                <img
                  src="/itemImage/<%= listings[i].id %>"
                  class="card-img-top listing-image"
                  alt="<%= listings[i].title %>"
                >

              <% } else if (listings[i].image) { %>

                <img
                  src="/images/<%= listings[i].image %>"
                  class="card-img-top listing-image"
                  alt="<%= listings[i].title %>"
                >

              <% } else { %>

                <div class="listing-placeholder">
                  No image uploaded
                </div>

              <% } %>

              <div class="card-body">

                <h5 class="card-title">
                  <%= listings[i].title %>
                </h5>

                <p class="card-text">

                  <strong>
                    $<%= Number(listings[i].price).toFixed(2) %>
                  </strong>

                </p>

                <p class="card-text text-muted">

                  <%= listings[i].condition %>

                  &middot;

                  <%= listings[i].category %>

                </p>

                <p class="card-text">
                  Meet-up:
                  <%= listings[i].location %>
                </p>

                <a
                  href="/listing/<%= listings[i].id %>"
                  class="btn btn-primary"
                >
                  View Details
                </a>

              </div>

            </div>

          </div>

        <% } %>

      </div>

    <% } else { %>

      <div class="alert alert-secondary text-center">
        No listings found. Create an account and add the first item.
      </div>

    <% } %>

  </div>

</body>
</html>