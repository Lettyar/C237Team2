<%- include('partials/head', { pageTitle: 'Marketplace' }) %>
<body>
  <%- include('partials/navbar', { activePage: 'marketplace' }) %>

  <main class="site-main">
    <div class="container app-container">
      <%- include('partials/flash') %>

      <section class="hero-panel mb-4" aria-labelledby="marketplace-title">
        <h1 id="marketplace-title">
          <% if (currentUser) { %>Welcome back, <%= currentUser.name %>.<% } else { %>Find more. Spend less.<% } %>
        </h1>
        <p>SellSpot makes it easy to discover quality second-hand items and give the things you no longer need a new home.</p>
        <div class="hero-note"><span aria-hidden="true">✓</span> Meet safely in public places and never share payment details.</div>
      </section>

      <section class="surface-card filter-panel mb-4" aria-label="Search marketplace listings">
        <form action="/" method="GET">
          <div class="row g-3 align-items-end">
            <div class="col-md-6 col-lg-4">
              <label for="search" class="form-label">Search items</label>
              <input type="search" class="form-control" id="search" name="search" value="<%= search %>" placeholder="Try “desk lamp” or “textbook”">
            </div>

            <div class="col-md-3 col-lg-3">
              <label for="category" class="form-label">Category</label>
              <select class="form-select" id="category" name="category">
                <option value="">All categories</option>
                <option value="Electronics" <%= category === 'Electronics' ? 'selected' : '' %>>Electronics</option>
                <option value="Fashion" <%= category === 'Fashion' ? 'selected' : '' %>>Fashion</option>
                <option value="Home" <%= category === 'Home' ? 'selected' : '' %>>Home</option>
                <option value="Books" <%= category === 'Books' ? 'selected' : '' %>>Books</option>
                <option value="Sports" <%= category === 'Sports' ? 'selected' : '' %>>Sports</option>
                <option value="Others" <%= category === 'Others' ? 'selected' : '' %>>Others</option>
              </select>
            </div>

            <div class="col-md-3 col-lg-3">
              <label for="condition" class="form-label">Condition</label>
              <select class="form-select" id="condition" name="condition">
                <option value="" <%= condition === '' ? 'selected' : '' %>>All conditions</option>
                <option value="new" <%= condition === 'new' ? 'selected' : '' %>>New</option>
                <option value="like_new" <%= condition === 'like_new' ? 'selected' : '' %>>Like New</option>
                <option value="good" <%= condition === 'good' ? 'selected' : '' %>>Good</option>
                <option value="fair" <%= condition === 'fair' ? 'selected' : '' %>>Fair</option>
                <option value="worn" <%= condition === 'worn' ? 'selected' : '' %>>Worn</option>
              </select>
            </div>

            <div class="col-lg-2 d-grid">
              <button type="submit" class="btn btn-primary">Search</button>
            </div>
          </div>
          <div class="mt-3">
            <a href="/" class="btn btn-outline-secondary btn-sm">Clear filters</a>
          </div>
        </form>
      </section>

      <section aria-labelledby="listings-title">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-3">
          <div>
            <h2 id="listings-title" class="mb-1">Marketplace listings</h2>
            <p class="text-muted mb-0">Browse items listed by the SellSpot community.</p>
          </div>
          <% if (currentUser) { %>
            <div class="d-flex flex-wrap gap-2">
              <a href="/myListings" class="btn btn-outline-secondary"><%= currentUser.role === 'admin' ? 'Manage listings' : 'My listings' %></a>
              <a href="/addListing" class="btn btn-primary">Sell an item</a>
            </div>
          <% } %>
        </div>

        <% if (listings.length > 0) { %>
          <div class="row g-4">
            <% for (let i = 0; i < listings.length; i++) { %>
              <div class="col-sm-6 col-lg-4">
                <article class="card listing-card">
                  <% if (listings[i].hasDatabaseImage) { %>
                    <img src="/itemImage/<%= listings[i].id %>" class="listing-image" alt="<%= listings[i].title %>">
                  <% } else if (listings[i].image) { %>
                    <img src="/images/<%= listings[i].image %>" class="listing-image" alt="<%= listings[i].title %>">
                  <% } else { %>
                    <div class="listing-placeholder" role="img" aria-label="No image uploaded">No image uploaded</div>
                  <% } %>

                  <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                      <h3 class="card-title h5 mb-0"><%= listings[i].title %></h3>
                      <span class="price-tag">$<%= Number(listings[i].price).toFixed(2) %></span>
                    </div>
                    <p class="listing-meta mb-2"><%= listings[i].condition %> &middot; <%= listings[i].category %></p>
                    <p class="small mb-2"><strong>Seller:</strong> <%= listings[i].sellerName %></p>
                    <p class="small text-muted mb-3"><strong>Meet-up:</strong> <%= listings[i].location || 'Not provided' %></p>
                    <a href="/listing/<%= listings[i].id %>" class="btn btn-primary">View details</a>
                  </div>
                </article>
              </div>
            <% } %>
          </div>
        <% } else { %>
          <div class="empty-state">
            <div class="empty-state-icon" aria-hidden="true">⌕</div>
            <h3 class="h5">No listings found</h3>
            <p class="mb-0">Try clearing your filters or check back soon for new items.</p>
          </div>
        <% } %>
      </section>
    </div>
  </main>

  <%- include('partials/footer') %>
