<!DOCTYPE html>
<html>
<head>
    <title>SellSpot</title>
</head>

<body>

    <h1>Welcome to SellSpot</h1>

    <p>Buy and sell affordable second-hand items.</p>

    <a href="/items">Browse Marketplace</a>

    <% if (currentUser) { %>
        <p>Welcome, <%= currentUser.name %>!</p>
        <a href="/logout">Logout</a>
    <% } else { %>
        <a href="/login">Login</a>
        <a href="/register">Register</a>
    <% } %>

</body>
</html>