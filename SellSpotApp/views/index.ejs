<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SellSpot</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container">
      <a class="navbar-brand" href="/">SellSpot</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="mainNavbar">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link active" href="/">Home</a></li>
          <% if (currentUser) { %>
            <li class="nav-item"><a class="nav-link" href="/addListing">Add Listing</a></li>
            <li class="nav-item"><a class="nav-link" href="/myListings"><%= currentUser.role === 'admin' ? 'Manage Listings' : 'My Listings' %></a></li>
          <% } %>
        </ul>
        <ul class="navbar-nav">
          <% if (currentUser) { %>
            <li class="nav-item"><span class="nav-link text-white"><%= currentUser.name %> (<%= currentUser.role %>)</span></li>
            <li class="nav-item"><a class="nav-link" href="/logout">Logout</a></li>
          <% } else { %>
            <li class="nav-item"><a class="nav-link" href="/register">Create Account</a></li>
            <li class="nav-item"><a class="nav-link" href="/login">Login</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <div class="alert alert-warning">
      <strong>Local practice mode:</strong> accounts and listings reset when the server restarts. MySQL will be connected after the team database is received.
    </div>

    <% if (success.length > 0) { %>
      <div class="alert alert-success"><%= success[0] %></div>
    <% } %>
    <% if (error.length > 0) { %>
      <div class="alert alert-danger"><%= error[0] %></div>
    <% } %>

    <div class="p-4 mb-4 bg-primary text-white rounded">
      <h1>Buy and sell second-hand items</h1>
      <p class="mb-0">Find affordable items or create a listing for something you no longer need.</p>
    </div>

    <form action="/" method="GET" class="card card-body mb-4">
      <div class="row g-3">
        <div class="col-md-6">
          <label for="search" class="form-label">Search item</label>
          <input type="text" class="form-control" id="search" name="search" value="<%= search %>" placeholder="Enter item name">
        </div>
        <div class="col-md-4">
          <label for="category" class="form-label">Category</label>
          <select class="form-select" id="category" name="category">
            <option value="">All categories</option>
            <option value="Electronics" <%= category === 'Electronics' ? 'selected' : '' %>>Electronics</option>
            <option value="Fashion" <%= category === 'Fashion' ? 'selected' : '' %>>Fashion</option>
            <option value="Home" <%= category === 'Home' ? 'selected' : '' %>>Home</option>
            <option value="Books" <%= category === 'Books' ? 'selected' : '' %>>Books</option>
            <option value="Others" <%= category === 'Others' ? 'selected' : '' %>>Others</option>
          </select>
        </div>
        <div class="col-md-2 d-grid align-items-end">
          <button type="submit" class="btn btn-dark">Search</button>
        </div>
      </div>
    </form>

    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2>Marketplace Listings</h2>
      <% if (currentUser) { %>
        <a href="/addListing" class="btn btn-success">Add New Listing</a>
      <% } %>
    </div>

    <% if (listings.length > 0) { %>
      <div class="row g-4">
        <% for (let i = 0; i < listings.length; i++) { %>
          <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm">
              <% if (listings[i].image) { %>
                <img src="/images/<%= listings[i].image %>" class="card-img-top listing-image" alt="<%= listings[i].title %>">
              <% } else { %>
                <div class="listing-placeholder">No image uploaded</div>
              <% } %>
              <div class="card-body">
                <h5 class="card-title"><%= listings[i].title %></h5>
                <p class="card-text"><strong>$<%= Number(listings[i].price).toFixed(2) %></strong></p>
                <p class="card-text text-muted"><%= listings[i].condition %> · <%= listings[i].category %></p>
                <p class="card-text">Meet-up: <%= listings[i].location %></p>
                <a href="/listing/<%= listings[i].id %>" class="btn btn-primary">View Details</a>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    <% } else { %>
      <div class="alert alert-secondary text-center">
        No listings found. Create an account and add the first item.
      </div>
    <% } %>
  </div>

  <footer class="text-center text-muted py-4 mt-5">SellSpot C237 CA2 Local Practice Version</footer>
</body>
</html>

