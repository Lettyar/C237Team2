<!DOCTYPE html>
<html>
<head>
    <title>SellSpot - Marketplace</title>
</head>

<body>

    <h1>Marketplace</h1>

    <% if (items.length === 0) { %>

        <p>No items are currently available</p>

    <% } else { %>

        <% items.forEach(item => { %>

            <div>
                <h2><%= item.name %></h2>

                <p>Price: $<%= item.price %></p>

                <p>Category: <%= item.category %></p>

                <p>Condition: <%= item.condition %></p>

                <a href="/item/<%= item.id %>">
                    View Details
                </a>
            </div>

            <hr>

        <% }); %>

    <% } %>

</body>
</html>