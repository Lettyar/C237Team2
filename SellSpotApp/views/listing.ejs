<%- include('partials/head', { pageTitle: listing.title }) %>
<body>
  <%- include('partials/navbar', { activePage: 'marketplace' }) %>

  <main class="site-main">
    <div class="container app-container">
      <%- include('partials/flash') %>

      <div class="mb-3">
        <a href="/" class="btn btn-outline-secondary">← Back to marketplace</a>
      </div>

      <article class="card overflow-hidden" aria-labelledby="listing-title">
        <div class="row g-0">
          <div class="col-lg-6">
            <% if (listing.hasDatabaseImage) { %>
              <img src="/itemImage/<%= listing.id %>" class="detail-image" alt="<%= listing.title %>">
            <% } else if (listing.image) { %>
              <img src="/images/<%= listing.image %>" class="detail-image" alt="<%= listing.title %>">
            <% } else { %>
              <div class="listing-placeholder h-100" role="img" aria-label="No image uploaded">No image uploaded</div>
            <% } %>
          </div>

          <div class="col-lg-6">
            <div class="card-body h-100 p-md-5">
              <p class="listing-meta mb-2"><%= listing.condition %> &middot; <%= listing.category %></p>
              <h1 id="listing-title" class="mb-2"><%= listing.title %></h1>
              <p class="price-tag mb-4">$<%= Number(listing.price).toFixed(2) %></p>

              <dl class="mb-4">
                <div class="mb-2"><dt class="detail-label">Meet-up</dt><dd class="d-inline"><%= listing.location || 'Not provided' %></dd></div>
                <div class="mb-2"><dt class="detail-label">Seller</dt><dd class="d-inline"><%= listing.sellerName %></dd></div>
              </dl>

              <div class="pt-3 border-top">
                <h2 class="h5">Description</h2>
                <p class="mb-0"><%= listing.description || 'No description was provided for this item.' %></p>
              </div>

              <% if (currentUser) { %>
                <div class="d-flex flex-wrap gap-2 mt-4">
                  <% if (currentUser.id === listing.sellerId) { %>
                    <a href="/editListing/<%= listing.id %>" class="btn btn-warning">Edit listing</a>
                  <% } %>
                  <% if (currentUser.role === 'admin' || currentUser.id === listing.sellerId) { %>
                    <form action="/deleteListing/<%= listing.id %>" method="POST" onsubmit="return confirm('Delete this listing?')">
                      <button type="submit" class="btn btn-danger">Delete listing</button>
                    </form>
                  <% } %>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </article>
    </div>
  </main>

  <%- include('partials/footer') %>
