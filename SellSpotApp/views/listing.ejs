<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= listing.title %> - SellSpot</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="navbar bg-dark navbar-dark">
    <div class="container">
      <a class="navbar-brand" href="/">SellSpot</a>
      <a class="btn btn-outline-light" href="/">Back to Marketplace</a>
    </div>
  </nav>

  <div class="container mt-5 mb-5">
    <% if (success.length > 0) { %>
      <div class="alert alert-success"><%= success[0] %></div>
    <% } %>
    <% if (error.length > 0) { %>
      <div class="alert alert-danger"><%= error[0] %></div>
    <% } %>

    <div class="card shadow">
      <div class="row g-0">
        <div class="col-md-6">
          <% if (listing.image) { %>
            <img src="/images/<%= listing.image %>" class="detail-image rounded-start" alt="<%= listing.title %>">
          <% } else { %>
            <div class="listing-placeholder h-100">No image uploaded</div>
          <% } %>
        </div>
        <div class="col-md-6">
          <div class="card-body p-4">
            <h1 class="card-title"><%= listing.title %></h1>
            <h3 class="text-primary mb-3">$<%= Number(listing.price).toFixed(2) %></h3>
            <p><strong>Category:</strong> <%= listing.category %></p>
            <p><strong>Condition:</strong> <%= listing.condition %></p>
            <p><strong>Meet-up Location:</strong> <%= listing.location %></p>
            <p><strong>Seller:</strong> <%= listing.sellerName %></p>
            <hr>
            <h5>Description</h5>
            <p><%= listing.description %></p>

            <% if (currentUser && (currentUser.role === 'admin' || currentUser.id === listing.sellerId)) { %>
              <div class="d-flex gap-2 mt-4">
                <a href="/editListing/<%= listing.id %>" class="btn btn-warning">Edit Listing</a>
                <a href="/deleteListing/<%= listing.id %>" class="btn btn-danger" onclick="return confirm('Delete this listing?')">Delete Listing</a>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>

