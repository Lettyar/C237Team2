<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <title>
    <%= currentUser.role === 'admin'
      ? 'Manage Listings'
      : 'My Listings'
    %> - SellSpot
  </title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <link rel="stylesheet" href="/style.css">
</head>

<body>

  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container">

      <a class="navbar-brand" href="/">
        SellSpot
      </a>

      <div>

        <a class="btn btn-success me-2" href="/addListing">
          Add Listing
        </a>

        <a class="btn btn-outline-light" href="/">
          Home
        </a>

      </div>
    </div>
  </nav>

  <div class="container mt-5">

    <% if (success && success.length > 0) { %>

      <div class="alert alert-success">
        <%= success[0] %>
      </div>

    <% } %>

    <% if (error && error.length > 0) { %>

      <div class="alert alert-danger">
        <%= error[0] %>
      </div>

    <% } %>

    <h1 class="mb-4">

      <%= currentUser.role === 'admin'
        ? 'Manage All Listings'
        : 'My Listings'
      %>

    </h1>

    <% if (listings.length > 0) { %>

      <div class="table-responsive">

        <table class="table table-hover align-middle bg-white shadow-sm">

          <thead class="table-dark">
            <tr>
              <th>Image</th>
              <th>Title</th>
              <th>Price</th>
              <th>Seller</th>
              <th>Meet-up Location</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody>

            <% for (let i = 0; i < listings.length; i++) { %>

              <tr>

                <td>

                  <% if (listings[i].hasDatabaseImage) { %>

                    <img
                      src="/itemImage/<%= listings[i].id %>"
                      width="80"
                      alt="<%= listings[i].title %>"
                    >

                  <% } else if (listings[i].image) { %>

                    <img
                      src="/images/<%= listings[i].image %>"
                      width="80"
                      alt="<%= listings[i].title %>"
                    >

                  <% } else { %>

                    No image

                  <% } %>

                </td>

                <td>

                  <a href="/listing/<%= listings[i].id %>">
                    <%= listings[i].title %>
                  </a>

                </td>

                <td>
                  $<%= Number(listings[i].price).toFixed(2) %>
                </td>

                <td>
                  <%= listings[i].sellerName %>
                </td>

                <td>
                  <%= listings[i].location || 'Not provided' %>
                </td>

                <td>

                  <a
                    href="/editListing/<%= listings[i].id %>"
                    class="btn btn-sm btn-warning"
                  >
                    Edit
                  </a>

                  <a
                    href="/deleteListing/<%= listings[i].id %>"
                    class="btn btn-sm btn-danger"
                    onclick="return confirm('Delete this listing?')"
                  >
                    Delete
                  </a>

                </td>

              </tr>

            <% } %>

          </tbody>
        </table>
      </div>

    <% } else { %>

      <div class="alert alert-secondary">
        There are no listings to manage.
      </div>

    <% } %>

  </div>

</body>
</html>