<%- include('partials/head', { pageTitle: currentUser.role === 'admin' ? 'Manage Listings' : 'My Listings' }) %>
<body>
  <%- include('partials/navbar', { activePage: 'listings' }) %>

  <main class="site-main">
    <div class="container app-container">
      <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end gap-3 page-heading">
        <div>
          <p class="text-uppercase small fw-bold mb-2"><%= currentUser.role === 'admin' ? 'Admin tools' : 'Selling dashboard' %></p>
          <h1><%= currentUser.role === 'admin' ? 'Manage all listings' : 'My listings' %></h1>
          <p><%= currentUser.role === 'admin' ? 'Review marketplace listings and remove items when needed.' : 'Keep your active listings accurate and up to date.' %></p>
        </div>
        <a class="btn btn-primary" href="/addListing">Add listing</a>
      </div>

      <%- include('partials/flash') %>

      <% if (listings.length > 0) { %>
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead class="table-dark">
              <tr>
                <th scope="col">Image</th>
                <th scope="col">Title</th>
                <th scope="col">Price</th>
                <th scope="col">Seller</th>
                <th scope="col">Meet-up</th>
                <th scope="col">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% for (let i = 0; i < listings.length; i++) { %>
                <tr>
                  <td>
                    <% if (listings[i].hasDatabaseImage) { %>
                      <img src="/itemImage/<%= listings[i].id %>" class="table-thumbnail" alt="<%= listings[i].title %>">
                    <% } else if (listings[i].image) { %>
                      <img src="/images/<%= listings[i].image %>" class="table-thumbnail" alt="<%= listings[i].title %>">
                    <% } else { %>
                      <span class="text-muted">No image</span>
                    <% } %>
                  </td>
                  <td><a class="fw-bold" href="/listing/<%= listings[i].id %>"><%= listings[i].title %></a></td>
                  <td>$<%= Number(listings[i].price).toFixed(2) %></td>
                  <td><%= listings[i].sellerName %></td>
                  <td><%= listings[i].location || 'Not provided' %></td>
                  <td>
                    <div class="d-flex flex-wrap gap-1">
                      <% if (currentUser.id === listings[i].sellerId) { %>
                        <a href="/editListing/<%= listings[i].id %>" class="btn btn-sm btn-warning">Edit</a>
                      <% } %>
                      <% if (currentUser.role === 'admin' || currentUser.id === listings[i].sellerId) { %>
                        <form action="/deleteListing/<%= listings[i].id %>" method="POST" onsubmit="return confirm('Delete this listing?')">
                          <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon" aria-hidden="true">+</div>
          <h2 class="h5">No listings yet</h2>
          <p class="mb-3">Create your first listing to start selling on SellSpot.</p>
          <a href="/addListing" class="btn btn-primary">Add a listing</a>
        </div>
      <% } %>
    </div>
  </main>

  <%- include('partials/footer') %>
