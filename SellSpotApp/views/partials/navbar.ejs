<nav class="navbar navbar-expand-lg site-navbar" aria-label="Primary navigation">
  <div class="container app-container">
    <a class="navbar-brand brand-mark" href="/" aria-label="SellSpot home">
      <span class="brand-icon" aria-hidden="true">S</span>
      <span>SellSpot</span>
    </a>

    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#siteNavbar"
      aria-controls="siteNavbar"
      aria-expanded="false"
      aria-label="Open navigation menu"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="siteNavbar">
      <ul class="navbar-nav me-auto align-items-lg-center">
        <li class="nav-item">
          <a class="nav-link <%= activePage === 'marketplace' ? 'active' : '' %>" href="/">Marketplace</a>
        </li>

        <% if (currentUser) { %>
          <li class="nav-item">
            <a class="nav-link <%= activePage === 'listings' ? 'active' : '' %>" href="/myListings">
              <%= currentUser.role === 'admin' ? 'Manage Listings' : 'My Listings' %>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= activePage === 'ratings' ? 'active' : '' %>" href="/ratings">Ratings</a>
          </li>
          <% if (currentUser.role === 'admin') { %>
            <li class="nav-item">
              <a class="nav-link <%= activePage === 'admin' ? 'active' : '' %>" href="/adminboard">Admin Board</a>
            </li>
          <% } %>
        <% } %>
      </ul>

      <div class="nav-actions">
        <button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch to dark mode" aria-pressed="false">
          <span class="theme-toggle-icon" data-theme-icon aria-hidden="true">☾</span>
          <span data-theme-label>Dark mode</span>
        </button>

        <% if (currentUser) { %>
          <span class="user-chip">
            <span class="user-chip-name"><%= currentUser.name %></span>
