<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ratings - SellSpot</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container">
      <a class="navbar-brand" href="/">
        <h3>SellSpot</h3>
      </a>
      <div class="ms-auto">
        <a class="btn btn-outline-light" href="/">Back to Home</a>
      </div>
    </div>
  </nav>

  <div class="container py-4">
    <h1 class="mb-3">User Ratings</h1>
    <p class="text-muted">Search for another user and leave a review with a rating from 1 to 5 stars and a short comment.</p>

    <% if (success && success.length > 0) { %>
      <div class="alert alert-success"><%= success[0] %></div>
    <% } %>

    <% if (error && error.length > 0) { %>
      <div class="alert alert-danger"><%= error[0] %></div>
    <% } %>

    <form method="GET" action="/ratings" class="card card-body mb-4">
      <div class="row g-3 align-items-end">

        <div class="col-md-8">
          <label for="search" class="form-label">Search user by name</label>
          <input type="text" class="form-control" id="search" name="search" value="<%= search %>" placeholder="Enter a user name">
        </div>

        <div class="col-md-4 d-grid">
          <button type="submit" class="btn btn-dark">Search</button>
        </div>
        
      </div>
    </form>

    <% if (users.length === 0) { %>
      <div class="alert alert-secondary">No users found. Try a different name.</div>
    <% } else { %>
      <div class="row g-4">
        <% users.forEach((user) => { %>
          <div class="col-md-6">
            <div class="card h-100">
              <div class="card-body">
                <h5 class="card-title"><%= user.full_name %></h5>
                <p class="mb-2 text-muted">Role: <%= user.role %></p>
                <p class="mb-2">Current rating: <strong><%= user.rating %>/5</strong></p>

                <% if (userListings[user.user_id] && userListings[user.user_id].length > 0) { %>
                  <form method="POST" action="/ratings" class="mt-3">
                    <input type="hidden" name="userId" value="<%= user.user_id %>">
                    <input type="hidden" name="search" value="<%= search %>">

                    <div class="mb-3">
                      <label class="form-label">Choose one of their listings</label>
                      <select class="form-select" name="itemId" required>
                        <option value="">Select a listing</option>
                        <% userListings[user.user_id].forEach((listing) => { %>
                          <option value="<%= listing.item_id %>"><%= listing.item_name %></option>
                        <% }) %>
                      </select>
                    </div>

                    <div class="mb-3">
                      <label class="form-label">Rating</label>
                      <select class="form-select" name="rating" required>
                        <option value="">Select stars</option>
                        <option value="5">5 Stars</option>
                        <option value="4">4 Stars</option>
                        <option value="3">3 Stars</option>
                        <option value="2">2 Stars</option>
                        <option value="1">1 Star</option>
                      </select>
                    </div>

                    <div class="mb-3">
                      <label class="form-label">Comment</label>
                      <textarea class="form-control" name="comment" rows="3" maxlength="500" placeholder="Share your experience with this user" required></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary">Post Review</button>
                  </form>
                <% } else { %>
                  <div class="alert alert-info mt-3 mb-0">This user does not have any listings yet.</div>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>
