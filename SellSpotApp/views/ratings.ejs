<%- include('partials/head', { pageTitle: 'Ratings' }) %>
<body>
  <%- include('partials/navbar', { activePage: 'ratings' }) %>

  <main class="site-main">
    <div class="container app-container">
      <div class="page-heading">
        <p class="text-uppercase small fw-bold mb-2">Community feedback</p>
        <h1>User ratings</h1>
        <p>Find a seller, choose one of their listings, and leave a thoughtful rating and comment.</p>
      </div>

      <%- include('partials/flash') %>

      <section class="surface-card filter-panel mb-4" aria-label="Search users">
        <form method="GET" action="/ratings">
          <div class="row g-3 align-items-end">
            <div class="col-md-8">
              <label for="search" class="form-label">Search user by name</label>
              <input type="search" class="form-control" id="search" name="search" value="<%= search %>" placeholder="Enter a user name">
            </div>
            <div class="col-md-4 d-grid"><button type="submit" class="btn btn-primary">Search users</button></div>
          </div>
        </form>
      </section>

      <% if (users.length === 0) { %>
        <div class="empty-state">
          <div class="empty-state-icon" aria-hidden="true">⌕</div>
          <h2 class="h5">No users found</h2>
          <p class="mb-0">Try a different name to find someone to review.</p>
        </div>
      <% } else { %>
        <div class="row g-4">
          <% users.forEach((user) => { %>
            <div class="col-md-6">
              <article class="card h-100">
                <div class="card-body">
                  <div class="d-flex justify-content-between gap-3 mb-3">
                    <div>
                      <h2 class="h5 mb-1"><%= user.full_name %></h2>
                      <p class="text-muted mb-0"><%= user.role %></p>
                    </div>
                    <span class="price-tag"><%= user.rating %>/5</span>
                  </div>

                  <% if (userListings[user.user_id] && userListings[user.user_id].length > 0) { %>
                    <form method="POST" action="/ratings">
                      <input type="hidden" name="userId" value="<%= user.user_id %>">
                      <input type="hidden" name="search" value="<%= search %>">

                      <div class="mb-3">
                        <label class="form-label" for="item-<%= user.user_id %>">Listing</label>
                        <select class="form-select" id="item-<%= user.user_id %>" name="itemId" required>
                          <option value="">Select a listing</option>
                          <% userListings[user.user_id].forEach((listing) => { %>
                            <option value="<%= listing.item_id %>"><%= listing.item_name %></option>
                          <% }) %>
                        </select>
                      </div>

                      <div class="mb-3">
                        <label class="form-label" for="rating-<%= user.user_id %>">Rating</label>
                        <select class="form-select" id="rating-<%= user.user_id %>" name="rating" required>
                          <option value="">Select stars</option>
                          <option value="5">5 stars</option>
                          <option value="4">4 stars</option>
                          <option value="3">3 stars</option>
                          <option value="2">2 stars</option>
                          <option value="1">1 star</option>
                        </select>
                      </div>

                      <div class="mb-3">
                        <label class="form-label" for="comment-<%= user.user_id %>">Comment</label>
                        <textarea class="form-control" id="comment-<%= user.user_id %>" name="comment" rows="3" maxlength="500" placeholder="Share your experience with this user" required></textarea>
                      </div>

                      <button type="submit" class="btn btn-primary">Post review</button>
                    </form>
                  <% } else { %>
                    <div class="alert alert-info mb-0">This user does not have any listings yet.</div>
                  <% } %>
                </div>
              </article>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </main>

  <%- include('partials/footer') %>
