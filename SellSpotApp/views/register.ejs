<%- include('partials/head', { pageTitle: 'Create Account' }) %>
<body>
  <%- include('partials/navbar', { activePage: '' }) %>

  <main class="site-main">
    <div class="container app-container">
      <div class="row justify-content-center">
        <div class="col-md-8 col-lg-5">
          <section class="card">
            <div class="card-body p-md-4">
              <div class="page-heading mb-4">
                <p class="text-uppercase small fw-bold mb-2">Join the community</p>
                <h1 class="h2">Create your account</h1>
                <p>Start finding great second-hand items or list something you no longer need.</p>
              </div>

              <%- include('partials/flash') %>

              <form action="/register" method="POST">
                <div class="mb-3">
                  <label for="full_name" class="form-label">Full name</label>
                  <input type="text" class="form-control" id="full_name" name="full_name" autocomplete="name" required>
                </div>
                <div class="mb-3">
                  <label for="email" class="form-label">Email</label>
                  <input type="email" class="form-control" id="email" name="email" autocomplete="email" required>
                  <div class="form-text">Any email or login name can be used for this local project.</div>
                </div>
                <div class="mb-4">
                  <label for="password" class="form-label">Password</label>
                  <input type="password" class="form-control" id="password" name="password" autocomplete="new-password" required>
                  <div class="form-text">Password must be more than 8 characters.</div>
                </div>
                <div class="d-grid gap-2">
                  <button type="submit" class="btn btn-primary">Create account</button>
                  <a href="/login" class="btn btn-secondary">I already have an account</a>
                </div>
              </form>
            </div>
          </section>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
